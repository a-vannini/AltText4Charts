  "events": [
    {
      "type": "point",
      "date": "2023-11-10",
      "label": "Am 10. November setzt das Gesundheitsministerium die tägliche Zählung der Toten zunächst aus. Zwei Tage später beginnt das Regierungspresseamt in Gaza, auf der Basis von Medienberichten eigene Zahlen zu publizieren."
    },
    {
      "type": "point",
      "date": "2023-12-02",
      "label": "Am 2. Dezember nimmt das Ministerium seine täglichen Updates wieder auf. "
    },
    {
      "type": "point",
      "date": "2024-01-06",
      "label": "Am 6. Januar führt das Ministerium ein Online-Formular ein, um Opfer zu melden."
    }
  ],
